{
  "max_diffusion_step": 2,
  "cl_decay_steps": 2000,
  "filter_type": "laplacian",
  "num_rnn_layers": 2,
  "rnn_units": 64,
  "use_curriculum_learning": true,
  "input_window": 12,
  "output_window": 12,

  "scaler": "standard",
  "load_external": false,
  "normal_external": false,
  "ext_scaler": "none",
  "add_time_in_day": false,
  "add_day_in_week": false,

  "max_epoch": 100,
  "learner": "adam",
  "learning_rate": 0.001,
  "lr_decay": false,
  "clip_grad_norm": true,
  "max_grad_norm": 5,
  "use_early_stop": false
}
